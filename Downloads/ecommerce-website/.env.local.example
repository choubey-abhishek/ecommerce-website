# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real secrets.

# --- Site URL --------------------------------------------------------------
# Only required in production. Leave blank locally — canonical URLs, OG
# tags, the sitemap, and Stripe's checkout success/cancel redirects all
# fall back to Vercel's auto-injected VERCEL_URL on preview deployments,
# then to the hardcoded production domain (see config/site.ts). Set this
# explicitly in Vercel's Production environment to your real custom domain.
NEXT_PUBLIC_SITE_URL=

# --- Authentication (Clerk) ---------------------------------------------
# Create a free application at https://dashboard.clerk.com to get these.
# Until both are set, the site runs fine with authentication disabled:
# Sign In/Sign Up show a "not configured yet" message instead of erroring,
# and every other page (Home, Shop, Product, Cart) works normally.
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/account
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/account

# --- Payments (Stripe) ---------------------------------------------------
# Create a free account at https://dashboard.stripe.com and use TEST mode
# keys while developing. Until STRIPE_SECRET_KEY is set, /checkout falls
# back to the "email this order to the studio" flow instead of erroring.
STRIPE_SECRET_KEY=
# From the Stripe Dashboard > Developers > Webhooks, once you add an
# endpoint pointing at /api/webhooks/stripe (use the Stripe CLI for local
# testing: `stripe listen --forward-to localhost:3000/api/webhooks/stripe`).
STRIPE_WEBHOOK_SECRET=

# --- Admin dashboard -------------------------------------------------------
# Comma-separated list of emails allowed into /admin. Requires Clerk to be
# configured above (sign in first, then add that email here). Anyone else
# who's signed in sees an access-restricted message, not the dashboard.
ADMIN_EMAILS=kopalsethstudio@gmail.com

# --- Database (Prisma / PostgreSQL) --------------------------------------
# Any Postgres works (Vercel Postgres, Supabase, Neon, Railway, or local).
# Until this is set, the site works identically — real orders are simply
# not *also* persisted locally (Stripe's dashboard remains the record of
# truth). Once set, run `npm run db:migrate` to create the Order/OrderItem
# tables.
DATABASE_URL=

# --- CMS (Sanity) — Journal / Blog ----------------------------------------
# Create a free project at https://www.sanity.io/manage. These two are
# public (safe to expose to the browser); add a token only if you need
# authenticated writes, which this app doesn't do.
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
# Until the project ID is set, /journal shows a "coming soon" state
# instead of erroring, and /admin/blog explains the same.

# --- Contact form + chatbot (Formspree) ----------------------------------
# Create a free form at https://formspree.io and paste its endpoint here
# (e.g. https://formspree.io/f/abcdwxyz). Every Contact-page and chatbot
# submission is sent here, arriving in the Gmail linked to that Formspree
# form. Until this is set, the form/chatbot show a "not configured" notice
# and offer an email fallback instead of erroring. Safe to expose publicly.
NEXT_PUBLIC_FORMSPREE_ENDPOINT=

# --- Analytics (Web Vitals -> GA4) ---------------------------------------
# Optional. Without this, Core Web Vitals (CLS/LCP/INP/etc.) are still
# logged to the browser console in development (see components/WebVitals.tsx)
# — nothing is silently dropped, there's just no production dashboard for
# them until both a GA4 property and its gtag.js script are wired up.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# --- Planned for later phases (not required yet) ------------------------
# CLOUDINARY_URL=                # Media storage/uploads (future)
